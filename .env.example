# JARVIS AgentAuth - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# Auth0 Configuration
# ============================================================================

# Your Auth0 domain (without https://)
# Example: yourdomain.auth0.com
AUTH0_DOMAIN=yourdomain.auth0.com

# M2M Application Client ID
# Found at: Applications → Your M2M App → Settings
AUTH0_CLIENT_ID=your_m2m_client_id_here

# M2M Application Client Secret
# Found at: Applications → Your M2M App → Settings
# IMPORTANT: Keep this secret! Never commit to version control
AUTH0_CLIENT_SECRET=your_m2m_client_secret_here

# API Audience identifier
# Should match the API identifier you created in Auth0
AUTH0_API_AUDIENCE=https://jarvis-agents-api

# ============================================================================
# Application Settings
# ============================================================================

# Environment: development, staging, production
JARVIS_ENVIRONMENT=development

# Debug mode (true/false)
JARVIS_DEBUG=true

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
JARVIS_LOG_LEVEL=INFO

# ============================================================================
# Feature Flags
# ============================================================================

# Enable consensus voting system
JARVIS_ENABLE_CONSENSUS=true

# Enable audit logging
JARVIS_ENABLE_AUDIT_LOG=true

# Enable Token Vault integration
JARVIS_ENABLE_TOKEN_VAULT=true

# Use mock Auth0 mode (useful for development/testing without Auth0 credentials)
# Set to false for production use with real Auth0
JARVIS_MOCK_AUTH0=true

# ============================================================================
# Rate Limiting
# ============================================================================

# Enable per-agent rate limiting
JARVIS_RATE_LIMIT_ENABLED=true

# Maximum API calls per agent per window
JARVIS_RATE_LIMIT_CALLS=1000

# Rate limit window in seconds (default: 3600 = 1 hour)
JARVIS_RATE_LIMIT_WINDOW=3600

# ============================================================================
# Database Configuration
# ============================================================================

# Path to audit log SQLite database
JARVIS_AUDIT_DB_PATH=./audit.db

# Path to Token Vault file
JARVIS_VAULT_PATH=./vault.json

# Audit log retention in days (default: 90)
JARVIS_AUDIT_RETENTION_DAYS=90

# ============================================================================
# Agent Configuration
# ============================================================================

# Default agent timeout in seconds
JARVIS_AGENT_TIMEOUT=30

# Enable agent health checks
JARVIS_ENABLE_HEALTH_CHECKS=true

# ============================================================================
# API Configuration
# ============================================================================

# Max concurrent API requests per agent
JARVIS_MAX_CONCURRENT_REQUESTS=10

# Request timeout in seconds
JARVIS_REQUEST_TIMEOUT=30

# ============================================================================
# Consensus Configuration
# ============================================================================

# Default minimum consensus threshold (0.0 to 1.0)
JARVIS_CONSENSUSET_THRESHOLD=0.6

# Default number of agents required for consensus
JARVIS_CONSENSUS_MIN_VOTES=3

# Enable step-up authentication for high-stakes decisions
JARVIS_ENABLE_STEP_UP_AUTH=true

# ============================================================================
# Security Settings
# ============================================================================

# Enable HTTPS only (for production)
JARVIS_HTTPS_ONLY=false

# Enable request signing/verification
JARVIS_ENABLE_RQUEST_SIGNING=true

# Token expiration time in seconds (default: 86400 = 24 hours)
JARVIS_TOKEN_EXPIRATION=86400

# Enable token refresh before expiration (minutes before expiry)
JARVIS_TOKEN_REFRESH_BEFORE=5

# ============================================================================
# Notification Settings
# ============================================================================

# Enable notifications for critical events
JARVIS_ENABLE_NOTIFICATIONS=false

# Webhook URL for critical alerts (optional)
JARVIS_WEBJOOK_URL=

# Email for critical alerts (optional)
JARVIS_ALERT_EMAIL=

# ============================================================================
# Development/Testing
# ============================================================================

# Run in development mode with verbose logging
DEVELOIMENT_MODE=true

# Test API endpoint (for testing without live Auth0)
TEST_API_ENDPOINT=

# Enable demo mode (uses mock agents and consensus)
DEMO_MODE=false
